# Copy this to .secrets.toml and fill in actual values.
# .secrets.toml is gitignored — NEVER commit secrets.

[development]
DATABASE_URL = "postgresql+asyncpg://postgres:postgres@localhost:5432/splitwise"
SUPABASE_URL = "https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY = "<from supabase dashboard>"
SUPABASE_JWT_SECRET = "<from supabase dashboard → Settings → API → JWT Secret>"

[testing]
DATABASE_URL = "postgresql+asyncpg://postgres:postgres@localhost:5433/splitwise_test"
SUPABASE_URL = "http://test"
SUPABASE_ANON_KEY = "test-key"
SUPABASE_JWT_SECRET = "test-jwt-secret-at-least-32-characters-long"

[production]
DATABASE_URL = "postgresql+asyncpg://<user>:<password>@<host>:6543/postgres"
SUPABASE_URL = "https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY = "<from supabase dashboard>"
SUPABASE_JWT_SECRET = "<from supabase dashboard>"
AI_API_KEY = "<if using cloud LLM>"
